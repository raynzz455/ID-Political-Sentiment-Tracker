# ==========================================
# ID-Sentiment-Tracker — Environment Template
# ==========================================
# Salin file ini ke .env di tiap subfolder yang butuh (ingestion, nlp-worker, frontend)
# Isi nilai dari Supabase Dashboard > Project Settings > API

# --- Supabase ---
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=eyJhbGci...your-anon-public-key...    # aman untuk frontend
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...your-service-role-key...  # RAHASIA: backend only!

# --- Ingestion (Layer 2) ---
# Daftar RSS feed URLs (dipisah koma). Lihat db.scraping_configs juga.
RSS_FEEDS=https://rss.detik.com/index.php/detik/politik,https://www.kompas.com/feeds/rss.xml

# --- NLP Worker (Layer 4) ---
# Model ONNX path lokal (di HF Spaces, letakkan di /data)
ONNX_MODEL_PATH=./models/indobert-sentiment-int8.onnx
NLP_BATCH_SIZE=16
NLP_MAX_LENGTH=128
# Worker dequeue interval (detik)
NLP_POLL_INTERVAL=30

# --- Frontend (Layer 6) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...your-anon-public-key...

# --- PGPQ queue name (di Supabase) ---
QUEUE_NAME=nlp_processing_queue
